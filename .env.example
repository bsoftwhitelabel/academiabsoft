# =============================================================================
# Variáveis de ambiente do frontend (Vite). Prefixo VITE_ é embutido no bundle.
# =============================================================================
# Vercel Dashboard → Settings → Environment Variables (Production, Preview, Dev):
#
#   Obrigatórias:
#     VITE_SUPABASE_URL
#     VITE_SUPABASE_ANON_KEY
#
#   Backend (mesma secção — lidas pela Serverless Function, não pelo bundle):
#     SUPABASE_URL              (= VITE_SUPABASE_URL)
#     SUPABASE_SERVICE_ROLE_KEY (secret; nunca expor ao cliente)
#
#   Opcionais na Vercel:
#     APP_ORIGIN                (domínio custom; omitir se usar *.vercel.app)
#     PUBLIC_APP_ORIGIN         (= APP_ORIGIN se omitido)
#
#   Não definir na Vercel: VITE_PDF_API_URL (ignorado em prod, mas evita confusão).
#   Não definir na Vercel: VITE_API_BASE (same-origin /api/*).

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-publica-do-supabase>

# Opcional: forçar base URL absoluta para a API (ex: preview → staging).
# Omitir = same-origin (/api/*; em dev o Vite faz proxy para :3001).
# VITE_API_BASE=https://staging-api.exemplo.com
