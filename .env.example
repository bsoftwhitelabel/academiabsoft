# =============================================================================
# Academia Digital — Environment Variables
# =============================================================================
# Local dev: copy this file to .env and fill in real values.
# Production (Vercel): set these in Project Settings → Environment Variables.

# ─── Database (REQUIRED) ──────────────────────────────────────────────────────
# Neon (recommended for Vercel):
#   postgresql://USER:PASS@HOST.neon.tech/academia_digital?sslmode=require&pgbouncer=true&connection_limit=1
# Supabase (transaction-mode pooler):
#   postgresql://postgres:PASS@aws-0-REGION.pooler.supabase.com:6543/postgres
# Local (docker compose up -d):
#   postgresql://postgres:postgres@localhost:5432/academia_digital?schema=public
DATABASE_URL=""

# ─── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# Must be at least 32 characters; rotate quarterly in production.
AUTH_SECRET=""

# Public URL of the deployment. Used to build magic-link URLs in emails.
AUTH_URL="http://localhost:3000"

# ─── Tenant resolution ────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_TENANT_SLUG="oportoforte"
NEXT_PUBLIC_BASE_DOMAIN="localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Email (Resend — optional in dev) ─────────────────────────────────────────
# When unset, magic-link URLs are printed to the server console.
RESEND_API_KEY=""
EMAIL_FROM="Academia Digital <noreply@example.com>"

# ─── Storage (Cloudflare R2 / S3 — optional, for signature uploads) ───────────
# Configure when wiring server-side signature persistence.
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="academia-digital"
STORAGE_PUBLIC_URL=""
