# =============================================================================
# Variáveis de ambiente do frontend (Vite). Prefixo VITE_ é embutido no bundle.
# =============================================================================
# Estas vars têm que estar no Vercel Dashboard (Environment Variables) para
# Production, Preview e Development.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-publica-do-supabase>

# Opcional: forçar base URL absoluta para a API (ex: preview → staging).
# Omitir = same-origin (/api/*; em dev o Vite faz proxy para :3001).
# VITE_API_BASE=https://staging-api.exemplo.com
#
# Legado (ainda lido se VITE_API_BASE não estiver definido):
# VITE_PDF_API_URL=http://localhost:3001
