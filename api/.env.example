# =============================================================================
# Variáveis de ambiente do backend (api/). NÃO commitar valores reais.
# Copiar para api/.env localmente. No Vercel, definir em Settings -> Env Vars.
# =============================================================================

# --- Supabase (servidor: bypassa RLS) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<eyJ... service_role JWT, formato Settings > API>

# --- CORS / origin ---
# Em produção, definir APP_ORIGIN para o domínio do frontend (ex:
# https://academia.bsoft.pt). Em dev, qualquer http://localhost:<porta> é aceite.
APP_ORIGIN=

# --- Tokens públicos psy ---
# Base usada para construir URLs /q/psy/<token> que o operador entrega ao RH.
PUBLIC_APP_ORIGIN=https://<dominio-do-frontend>

# --- Tenant operador (para scripts seed) ---
PSY_SEED_TENANT_ID=<cuid-do-tenant-operador>

# --- Postgres directo (só para scripts: aplicar migrações, audits, seed) ---
# Vercel: NÃO definir esta var em prod (não é usada pela função; só por scripts
# locais que aplicam DDL ao Supabase).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- PDFs (Puppeteer) ---
# Bucket Supabase Storage para PDFs gerados pelo dossier. Não usado em
# serverless (Vercel skipa /api/pdf/* via flag VERCEL).
PDF_BUCKET=dossier-pdfs

# --- Flags ---
# Quando =1, desliga a rota /api/pdf mesmo em Node local (útil para testar o
# comportamento serverless localmente). Em Vercel é setada automaticamente
# via VERCEL=1.
# SKIP_PDF_ROUTE=1

# --- Local dev only ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
